# 后端可选配置。复制为 .env 后由你的启动方式加载，或直接在 shell 中 export。

# MinerU CLI 路径；不配置时会自动查找 backend/python-worker/.venv/bin/mineru、
# Python worker venv 内的 MinerU entry point 或 PATH。
MINERU_COMMAND=
MINERU_API_ENABLED=true
MINERU_API_HOST=127.0.0.1
MINERU_API_PORT=8002
MINERU_API_URL=http://127.0.0.1:8002
MINERU_API_MAX_CONCURRENT_REQUESTS=1
MINERU_API_ENABLE_VLM_PRELOAD=false

# 可选：MinerU 离线 wheelhouse 路径。TOGO 带大包交付时默认放在 vendor/mineru-wheelhouse。
MINERU_WHEELHOUSE=vendor/mineru-wheelhouse

# OCR 超时秒数。
MINERU_TIMEOUT_SECONDS=1800
MINERU_VERSION_TIMEOUT_SECONDS=30
# 服务器多 GPU 时优先通过 NVIDIA_VISIBLE_DEVICES 固定物理卡。
# 当前服务器约定：AI_GENERATION / MinerU OCR 使用物理 GPU0，vLLM / aux-qwen3-32b-fp8 使用物理 GPU1。
# 容器内只暴露物理 GPU0 后，CUDA_VISIBLE_DEVICES 应保持 0。
NVIDIA_VISIBLE_DEVICES=0
OCR_CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,max_split_size_mb:512
MINERU_VIRTUAL_VRAM_SIZE=48
MINERU_HYBRID_BATCH_RATIO=16

# 是否启用大模型拆题。未配置 DEEPSEEK_API_KEY / DASHSCOPE_API_KEY 时会自动回退本地规则。
ENABLE_LLM_SPLIT=true

# OpenAI 兼容接口配置。不要提交真实密钥。
# 当前外部满血模型默认走 TokenHub。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://tokenhub.shwfl.edu.cn/v1
DEEPSEEK_MODEL=qwen3.7-max
LLM_MODEL=qwen3.7-max
# 兼容旧变量名。新部署优先使用 DEEPSEEK_*，旧 DashScope Key 不应提交。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://tokenhub.shwfl.edu.cn/v1
DASHSCOPE_MODEL=qwen3.7-max
LLM_PROVIDER=tokenhub
LLM_SPLIT_TIMEOUT_SECONDS=90
LLM_SPLIT_MAX_CHARS=30000
LLM_BOUNDARY_TIMEOUT_SECONDS=90
LLM_BOUNDARY_MAX_CHARS=30000
LLM_BOUNDARY_MAX_TOKENS=4096
LLM_STANDARDIZE_TIMEOUT_SECONDS=60
AI_STANDARDIZE_CACHE_TTL_SECONDS=300

# LLM router.
# 本地开发默认 external-only，保证所有 AI 节点稳定走外部 deepseek-v4-pro。
# 服务器部署可显式改为 hybrid，并开启 LOCAL_LLM_ENABLED=true。
# hybrid 下 AI 边界确认 boundary-refine 仍默认走外部满血模型；
# 本地 aux 模型只默认承接小问结构、标准化等低风险结构任务。
LLM_ROUTER_MODE=external
LLM_EXTERNAL_ENABLED=true
LLM_EXTERNAL_FALLBACK_ENABLED=true
LLM_EXTERNAL_MAX_CONCURRENCY=8
LLM_ROUTER_EXTERNAL_FIRST_RISK_THRESHOLD=0.92
LLM_ROUTER_CACHE_ENABLED=true
LLM_ROUTER_CACHE_TTL_SECONDS=300
LOCAL_LLM_ENABLED=false
LOCAL_LLM_PROVIDER=local-openai-compatible
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_LLM_API_KEY=EMPTY
LOCAL_LLM_MODEL=aux-qwen3-32b-fp8
LOCAL_LLM_MAX_CONCURRENCY=4
LOCAL_LLM_DEFAULT_TIMEOUT_SECONDS=45
LOCAL_LLM_BOUNDARY_REFINE_TIMEOUT_SECONDS=45
LOCAL_LLM_STANDARDIZE_TIMEOUT_SECONDS=45
LOCAL_LLM_DISABLE_THINKING=true

# LLM efficiency controls. Keep external model concurrency within gateway rate limits.
LLM_MAX_CONCURRENCY=1
LLM_BOUNDARY_CHUNK_SIZE=5
LLM_BOUNDARY_MAX_CONCURRENCY=4
LLM_STANDARDIZE_INITIAL_CONCURRENCY=4
LLM_STANDARDIZE_MIN_CONCURRENCY=2
LLM_STANDARDIZE_MAX_CONCURRENCY=8
LLM_STANDARDIZE_SUCCESS_WINDOW=20
LLM_STANDARDIZE_COOLDOWN_SECONDS=30
AI_STANDARDIZATION_MAX_CONCURRENCY=12
LLM_ANALYSIS_MAX_CONCURRENCY=4
LLM_STANDARDIZE_MAX_ATTEMPTS=2
LLM_ANALYSIS_MAX_ATTEMPTS=2
LLM_STANDARDIZE_RETRY_AFTER_SECONDS=10
LLM_ANALYSIS_RETRY_AFTER_SECONDS=10
LLM_METRICS_ENABLED=true

# OCR automatic semantic repair mode:
# skip: do not run automatic AI semantic repair in OCR main path
# inline: run repairs serially for diagnostics
# inline-concurrent: run eligible repairs with bounded concurrency
OCR_AUTO_SEMANTIC_REPAIR_MODE=skip

# 可选：OCR 视觉修复。默认启用本地题目 crop + 横线检测；Pix2Text 未配置时会自动跳过二次 OCR。
OCR_VISUAL_REPAIR_ENABLED=true
OCR_VISUAL_REPAIR_MAX_CONCURRENCY=2
OCR_VISUAL_REPAIR_PRELOAD_ENABLED=true
OCR_VISUAL_REPAIR_PRELOAD_MAX_PAGES=4
OCR_VISUAL_REPAIR_PDF_RENDER_SCALE=2.0
OCR_VISUAL_REPAIR_MIN_UNDERLINE_WIDTH_RATIO=0.12
OCR_VISUAL_REPAIR_APPLY_PIX2TEXT=true
PIX2TEXT_COMMAND=
PIX2TEXT_TIMEOUT_SECONDS=45

# 试卷 PDF 导出使用 Pandoc + XeLaTeX 时的中文字体；不配置时默认尝试 Songti SC。
PANDOC_CJK_FONT=

# Java 主后端第一阶段并行服务配置。
JAVA_BACKEND_PORT=8018
JAVA_BACKEND_PROFILE=test
SPRING_PROFILES_ACTIVE=test
PYTHON_WORKER_ENABLED=true
PYTHON_WORKER_API_PROXY_ENABLED=true
PYTHON_WORKER_BASE_URL=http://127.0.0.1:8000
PYTHON_WORKER_STORAGE_ROOT=
PYTHON_WORKER_HEALTH_PATH=/api/health
PYTHON_WORKER_CONNECT_TIMEOUT_MS=2000
PYTHON_WORKER_READ_TIMEOUT_MS=300000

# 生产平台接入安全兜底校验。本地默认关闭；生产建议开启，并由平台网关或 BFF 注入上下文。
PLATFORM_SECURITY_CONTEXT_VALIDATION_ENABLED=false
PLATFORM_SECURITY_AUTHORIZATION_REQUIRED=true
PLATFORM_SECURITY_REQUIRED_HEADERS=X-Tenant-Id,X-Operator-Id
PLATFORM_SECURITY_EXCLUDED_PATH_PREFIXES=/actuator,/v3/api-docs,/swagger-ui,/doc.html,/webjars,/favicon.ico,/api/java/health,/api/java/worker,/api/java/stack,/api/java/enterprise

# 可选：本地企业化依赖。仅供 docker-compose.local.yml 使用，不要在这里写生产密码。
LOCAL_MYSQL_ROOT_PASSWORD=ai_generation_root
LOCAL_MYSQL_DATABASE=ai_generation
LOCAL_MYSQL_USER=ai_generation
LOCAL_MYSQL_PASSWORD=ai_generation
LOCAL_REDIS_PORT=6379
LOCAL_MINIO_ROOT_USER=minioadmin
LOCAL_MINIO_ROOT_PASSWORD=minioadmin

# 可选：服务器 Docker Compose 部署端口。真实密钥仍只写 .env 或由服务器密钥管理注入。
APP_HTTP_PORT=80
APP_COMPAT_HTTP_PORT=5173
APP_JAVA_PORT=8018
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://192.168.1.148:*,http://120.211.112.121,http://120.211.112.121:*,https://*.pinggy-free.link,https://*.free.pinggy.net,https://*.lhr.life
SERVER_BASE_IMAGE=python:3.11-slim-bookworm
HOST_MINERU_VENV=
