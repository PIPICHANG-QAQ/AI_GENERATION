# 后端可选配置。复制为 .env 后由你的启动方式加载，或直接在 shell 中 export。

# MinerU CLI 路径；不配置时会自动查找 backend/python-worker/.venv/bin/mineru、
# Python worker venv 内的 MinerU entry point 或 PATH。
MINERU_COMMAND=

# 可选：MinerU 离线 wheelhouse 路径。TOGO 带大包交付时默认放在 vendor/mineru-wheelhouse。
MINERU_WHEELHOUSE=vendor/mineru-wheelhouse

# OCR 超时秒数。
MINERU_TIMEOUT_SECONDS=1800
MINERU_VERSION_TIMEOUT_SECONDS=30

# 是否启用大模型拆题。未配置 DEEPSEEK_API_KEY / DASHSCOPE_API_KEY 时会自动回退本地规则。
ENABLE_LLM_SPLIT=true

# DeepSeek / OpenAI 兼容接口配置。不要提交真实密钥。
# 方案 A：使用 DeepSeek 官方 Key。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# 方案 B：沿用旧部署 Key，通过百炼或平台模型网关路由到 deepseek-v4-pro。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=deepseek-v4-pro
LLM_PROVIDER=
LLM_SPLIT_TIMEOUT_SECONDS=90
LLM_SPLIT_MAX_CHARS=30000
LLM_BOUNDARY_TIMEOUT_SECONDS=90
LLM_BOUNDARY_MAX_CHARS=30000

# 可选：OCR 视觉修复。默认启用本地题目 crop + 横线检测；Pix2Text 未配置时会自动跳过二次 OCR。
OCR_VISUAL_REPAIR_ENABLED=true
OCR_VISUAL_REPAIR_PDF_RENDER_SCALE=2.0
OCR_VISUAL_REPAIR_MIN_UNDERLINE_WIDTH_RATIO=0.12
OCR_VISUAL_REPAIR_APPLY_PIX2TEXT=true
PIX2TEXT_COMMAND=
PIX2TEXT_TIMEOUT_SECONDS=45

# 试卷 PDF 导出使用 Pandoc + XeLaTeX 时的中文字体；不配置时默认尝试 Songti SC。
PANDOC_CJK_FONT=

# Java 主后端第一阶段并行服务配置。
JAVA_BACKEND_PORT=8018
JAVA_BACKEND_PROFILE=test
SPRING_PROFILES_ACTIVE=test
PYTHON_WORKER_ENABLED=true
PYTHON_WORKER_API_PROXY_ENABLED=true
PYTHON_WORKER_BASE_URL=http://127.0.0.1:8000
PYTHON_WORKER_STORAGE_ROOT=
PYTHON_WORKER_HEALTH_PATH=/api/health
PYTHON_WORKER_CONNECT_TIMEOUT_MS=2000
PYTHON_WORKER_READ_TIMEOUT_MS=300000

# 生产平台接入安全兜底校验。本地默认关闭；生产建议开启，并由平台网关或 BFF 注入上下文。
PLATFORM_SECURITY_CONTEXT_VALIDATION_ENABLED=false
PLATFORM_SECURITY_AUTHORIZATION_REQUIRED=true
PLATFORM_SECURITY_REQUIRED_HEADERS=X-Tenant-Id,X-Operator-Id
PLATFORM_SECURITY_EXCLUDED_PATH_PREFIXES=/actuator,/v3/api-docs,/swagger-ui,/doc.html,/webjars,/favicon.ico,/api/java/health,/api/java/worker,/api/java/stack,/api/java/enterprise

# 可选：本地企业化依赖。仅供 docker-compose.local.yml 使用，不要在这里写生产密码。
LOCAL_MYSQL_ROOT_PASSWORD=ai_generation_root
LOCAL_MYSQL_DATABASE=ai_generation
LOCAL_MYSQL_USER=ai_generation
LOCAL_MYSQL_PASSWORD=ai_generation
LOCAL_REDIS_PORT=6379
LOCAL_MINIO_ROOT_USER=minioadmin
LOCAL_MINIO_ROOT_PASSWORD=minioadmin

# 可选：服务器 Docker Compose 部署端口。真实密钥仍只写 .env 或由服务器密钥管理注入。
APP_HTTP_PORT=80
APP_JAVA_PORT=8018
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://192.168.1.148:*,http://120.211.112.121:*,https://*.pinggy-free.link,https://*.free.pinggy.net,https://*.lhr.life
SERVER_BASE_IMAGE=python:3.11-slim-bookworm
HOST_MINERU_VENV=
